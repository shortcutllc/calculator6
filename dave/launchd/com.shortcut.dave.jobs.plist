<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Dave's scheduled jobs. launchd (not cron) because StartCalendarInterval jobs missed
     during sleep FIRE ON WAKE — a sleeping Mac delays Dave's work instead of losing it.
     Each fire runs every job; run-job.sh's watermarks + prechecks make extra fires free,
     so overlapping schedules cost $0. -->
<dict>
  <key>Label</key><string>com.shortcut.dave.jobs</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>D=/Users/willnewton/Documents/GitHub/calculator6/dave/jobs; "$D/run-job.sh" monday-strategy; "$D/run-job.sh" morning-brief; "$D/run-job.sh" influence-scan; "$D/run-job.sh" nightly-status</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>5</integer></dict>
    <dict><key>Hour</key><integer>21</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key><string>/Users/willnewton/Documents/GitHub/calculator6/dave/state/logs/jobs.out</string>
  <key>StandardErrorPath</key><string>/Users/willnewton/Documents/GitHub/calculator6/dave/state/logs/jobs.err</string>
</dict>
</plist>
